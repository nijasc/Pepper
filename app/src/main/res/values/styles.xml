<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AdminKey">
        <item name="android:layout_width">96dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:background">@drawable/bg_pill_teal</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">28sp</item>
    </style>

    <style name="AdminMenuButton">
        <item name="android:layout_width">340dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:paddingTop">18dp</item>
        <item name="android:paddingBottom">18dp</item>
        <item name="android:background">@drawable/bg_pill_teal</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="AdminMenuTile">
        <item name="android:layout_width">@dimen/admin_tile_width</item>
        <item name="android:layout_height">@dimen/admin_tile_height</item>
        <item name="android:layout_margin">@dimen/space_s</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">@dimen/space_m</item>
        <item name="android:background">@drawable/bg_pill_teal</item>
        <item name="android:foreground">?android:attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="NavPill">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_pill_teal</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">28dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingRight">28dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">18sp</item>
    </style>

    <!-- Admin design system -->
    <style name="AdminTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AdminSectionLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/buhler_teal</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="AdminPrimaryButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_pill_teal</item>
        <item name="android:paddingLeft">@dimen/admin_pill_padding_h</item>
        <item name="android:paddingTop">@dimen/admin_pill_padding_v</item>
        <item name="android:paddingRight">@dimen/admin_pill_padding_h</item>
        <item name="android:paddingBottom">@dimen/admin_pill_padding_v</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <style name="AdminDangerButton" parent="AdminPrimaryButton">
        <item name="android:background">@drawable/bg_pill_red</item>
    </style>

    <style name="AdminStatusTile">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">@dimen/space_s</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">@dimen/space_m</item>
        <item name="android:background">@drawable/bg_admin_card</item>
    </style>
</resources>
