<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    tools:parentTag="android.widget.FrameLayout"
    xmlns:tools="http://schemas.android.com/tools">

    <ScrollView
        android:id="@+id/danceScrollRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dance_title"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/dance_subtitle"
                android:textColor="#CCFFFFFF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/danceCreate"
                style="@style/NavPill"
                android:layout_marginTop="16dp"
                android:text="@string/dance_create" />

            <LinearLayout
                android:id="@+id/danceList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/danceClose"
                style="@style/NavPill"
                android:layout_marginTop="28dp"
                android:text="@string/dance_close" />
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/danceLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ProgressBar
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/danceLoadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/danceLoadingEta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/dance_create_eta"
                android:textColor="#99FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>
</merge>
