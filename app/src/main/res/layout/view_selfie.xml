<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="android.widget.FrameLayout">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="24dp">

        <ImageView
            android:id="@+id/selfiePhoto"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:adjustViewBounds="true"
            android:background="@color/black"
            android:contentDescription="@string/selfie_title"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="24dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/selfieTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/selfie_title"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/selfieQr"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginTop="12dp"
                android:background="@color/white"
                android:contentDescription="@string/selfie_scan_hint"
                android:padding="10dp"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/selfieScanHint"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/selfie_scan_hint"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/selfieWifiBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/selfieWifiQr"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:background="@color/white"
                    android:contentDescription="@string/selfie_wifi_hint"
                    android:padding="10dp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/selfieWifiHint"
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text="@string/selfie_wifi_hint"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/selfieOkay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_pill_teal"
                android:paddingLeft="44dp"
                android:paddingTop="14dp"
                android:paddingRight="44dp"
                android:paddingBottom="14dp"
                android:text="@string/selfie_okay"
                android:textColor="@color/white"
                android:textSize="20sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/selfieStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16dp"
        android:text="@string/selfie_title"
        android:textColor="@color/buhler_teal"
        android:textSize="22sp" />
</merge>
