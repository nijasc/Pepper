<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="160dp"
    android:layout_height="160dp"
    android:layout_margin="6dp">

    <ImageView
        android:id="@+id/itemSelfieImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:contentDescription="@string/admin_selfies"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/itemSelfieNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:background="#99000000"
        android:paddingLeft="8dp"
        android:paddingTop="2dp"
        android:paddingRight="8dp"
        android:paddingBottom="2dp"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/itemSelfieStar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:padding="6dp"
        android:text="★"
        android:textColor="#FFD54F"
        android:textSize="22sp"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/itemSelfieRaffle"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|start"
        android:layout_margin="4dp"
        android:background="#99000000"
        android:contentDescription="@string/admin_raffle"
        android:padding="4dp"
        android:src="@drawable/ic_admin_raffle"
        android:visibility="gone" />
</FrameLayout>
