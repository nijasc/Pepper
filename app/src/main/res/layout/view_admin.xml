<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="android.widget.FrameLayout">

    <LinearLayout
        android:id="@+id/adminPinPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_pin_title"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminPinDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:letterSpacing="0.3"
            android:text="○ ○ ○ ○"
            android:textColor="@color/buhler_teal"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/adminPinError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/admin_pin_error"
            android:textColor="@color/pad_red"
            android:textSize="18sp"
            android:visibility="invisible" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey1" style="@style/AdminKey" android:text="1" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey2" style="@style/AdminKey" android:text="2" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey3" style="@style/AdminKey" android:text="3" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey4" style="@style/AdminKey" android:text="4" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey5" style="@style/AdminKey" android:text="5" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey6" style="@style/AdminKey" android:text="6" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey7" style="@style/AdminKey" android:text="7" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey8" style="@style/AdminKey" android:text="8" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey9" style="@style/AdminKey" android:text="9" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKeyClear" style="@style/AdminKey" android:text="@string/admin_key_clear" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey0" style="@style/AdminKey" android:text="0" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKeyBackspace" style="@style/AdminKey" android:text="@string/admin_key_backspace" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminPinCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@android:color/transparent"
            android:text="@string/admin_cancel"
            android:textColor="#CCFFFFFF"
            android:textSize="18sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminMenuPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="@string/admin_menu_title"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="4">

            <LinearLayout android:id="@+id/adminClearHistory" style="@style/AdminMenuTile">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/admin_clear_history"
                    android:src="@drawable/ic_admin_history_clear" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/admin_clear_history"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/adminDevLogs" style="@style/AdminMenuTile">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/admin_dev_logs"
                    android:src="@drawable/ic_admin_devlog" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/admin_dev_logs"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/adminSelfies" style="@style/AdminMenuTile">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/admin_selfies"
                    android:src="@drawable/ic_admin_selfies" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/admin_selfies"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/adminLanguage" style="@style/AdminMenuTile">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/admin_language"
                    android:src="@drawable/ic_admin_language" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/admin_language"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/adminHistory" style="@style/AdminMenuTile">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/admin_history_view"
                    android:src="@drawable/ic_admin_history" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/admin_history_view"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/adminRaffle" style="@style/AdminMenuTile">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/admin_raffle"
                    android:src="@drawable/ic_admin_raffle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/admin_raffle"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/adminCamera" style="@style/AdminMenuTile">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/admin_camera"
                    android:src="@drawable/ic_admin_camera" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/admin_camera"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/adminNavigation" style="@style/AdminMenuTile">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/admin_navigation"
                    android:src="@drawable/ic_admin_navigation" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/admin_navigation"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/adminDances" style="@style/AdminMenuTile">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/admin_dances"
                    android:src="@drawable/ic_admin_dance" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/admin_dances"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/adminClose" style="@style/AdminMenuTile">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/admin_close"
                    android:src="@drawable/ic_admin_close" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="@string/admin_close"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>
        </GridLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminDevLogPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_dev_logs"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <ScrollView
            android:id="@+id/adminDevLogScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/adminDevLogText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="#DDFFFFFF"
                android:textSize="15sp" />
        </ScrollView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminDevLogBack"
            style="@style/AdminMenuButton"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="@string/admin_back" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminGalleryPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_selfies"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/adminSelfieGrid"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/adminGalleryEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/admin_no_selfies"
                android:textColor="#CCFFFFFF"
                android:textSize="20sp"
                android:visibility="gone" />
        </FrameLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminExportAll"
            style="@style/AdminMenuButton"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="@string/admin_export_all" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminGalleryBack"
            style="@style/AdminMenuButton"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="@string/admin_back" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminDetailPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/adminDetailImage"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:contentDescription="@string/admin_selfies"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/adminDetailNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminDetailDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#CCFFFFFF"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/adminDetailQr"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginTop="10dp"
            android:background="@color/white"
            android:contentDescription="@string/selfie_scan_hint"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminDetailFavorite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_pill_teal"
                android:paddingLeft="28dp"
                android:paddingTop="14dp"
                android:paddingRight="28dp"
                android:paddingBottom="14dp"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminDetailDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_red"
                android:paddingLeft="28dp"
                android:paddingTop="14dp"
                android:paddingRight="28dp"
                android:paddingBottom="14dp"
                android:text="@string/admin_delete"
                android:textColor="@color/white"
                android:textSize="18sp" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminDetailBack"
            style="@style/AdminMenuButton"
            android:layout_marginTop="10dp"
            android:text="@string/admin_back" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminLangPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/admin_language"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminLangCurrent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColor="@color/buhler_teal"
            android:textSize="20sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminLangDe"
            style="@style/AdminMenuButton"
            android:text="@string/lang_german" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminLangEn"
            style="@style/AdminMenuButton"
            android:text="@string/lang_english" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminLangBack"
            style="@style/AdminMenuButton"
            android:layout_marginTop="24dp"
            android:text="@string/admin_back" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminHistoryPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_history_view"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <ScrollView
            android:id="@+id/adminHistoryScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:id="@+id/adminHistoryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminHistoryBack"
            style="@style/AdminMenuButton"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="@string/admin_back" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminRaffleCreatePanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/raffle_create_title"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/raffleTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/raffle_title_hint"
                    android:inputType="text"
                    android:textColor="@color/white"
                    android:textColorHint="#88FFFFFF" />

                <EditText
                    android:id="@+id/raffleDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="top"
                    android:hint="@string/raffle_description_hint"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:textColor="@color/white"
                    android:textColorHint="#88FFFFFF" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/raffleDescriptionDone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_pill_teal"
                    android:paddingLeft="20dp"
                    android:paddingTop="8dp"
                    android:paddingRight="20dp"
                    android:paddingBottom="8dp"
                    android:text="@string/raffle_keyboard_done"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/raffleEndDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_pill_teal"
                    android:paddingLeft="28dp"
                    android:paddingTop="12dp"
                    android:paddingRight="28dp"
                    android:paddingBottom="12dp"
                    android:text="@string/raffle_end_date"
                    android:textColor="@color/white"
                    android:textSize="18sp" />

                <CheckBox
                    android:id="@+id/raffleRequiresSelfie"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/raffle_requires_selfie"
                    android:textColor="@color/white"
                    android:textSize="18sp" />

                <CheckBox
                    android:id="@+id/raffleRequiresPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/raffle_requires_phone"
                    android:textColor="@color/white"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/raffleCreateError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/pad_red"
                    android:textSize="16sp"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/raffleCreateSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_pill_teal"
                android:paddingLeft="40dp"
                android:paddingTop="14dp"
                android:paddingRight="40dp"
                android:paddingBottom="14dp"
                android:text="@string/raffle_save"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/raffleCreateBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_teal"
                android:paddingLeft="40dp"
                android:paddingTop="14dp"
                android:paddingRight="40dp"
                android:paddingBottom="14dp"
                android:text="@string/admin_back"
                android:textColor="@color/white"
                android:textSize="18sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminRafflePanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/adminRaffleTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminRaffleStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/buhler_teal"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/adminRaffleWinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_pill_teal"
            android:padding="12dp"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:id="@+id/adminRaffleEntries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminRaffleDraw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_pill_teal"
                android:paddingLeft="32dp"
                android:paddingTop="14dp"
                android:paddingRight="32dp"
                android:paddingBottom="14dp"
                android:text="@string/raffle_draw"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminRaffleRedraw"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_pill_teal"
                android:paddingLeft="32dp"
                android:paddingTop="14dp"
                android:paddingRight="32dp"
                android:paddingBottom="14dp"
                android:text="@string/raffle_redraw"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminRaffleEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_teal"
                android:paddingLeft="32dp"
                android:paddingTop="14dp"
                android:paddingRight="32dp"
                android:paddingBottom="14dp"
                android:text="@string/raffle_email_send"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminRaffleClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_pill_teal"
                android:paddingLeft="40dp"
                android:paddingTop="14dp"
                android:paddingRight="40dp"
                android:paddingBottom="14dp"
                android:text="@string/raffle_close_now"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminRaffleFinish"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_pill_red"
                android:paddingLeft="40dp"
                android:paddingTop="14dp"
                android:paddingRight="40dp"
                android:paddingBottom="14dp"
                android:text="@string/raffle_finish"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminRaffleDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_pill_red"
                android:paddingLeft="40dp"
                android:paddingTop="14dp"
                android:paddingRight="40dp"
                android:paddingBottom="14dp"
                android:text="@string/raffle_delete"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminRaffleBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_teal"
                android:paddingLeft="40dp"
                android:paddingTop="14dp"
                android:paddingRight="40dp"
                android:paddingBottom="14dp"
                android:text="@string/admin_back"
                android:textColor="@color/white"
                android:textSize="18sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminCameraPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_camera_title"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/cameraIp"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/camera_ip_hint"
            android:inputType="number|numberDecimal"
            android:digits="0123456789."
            android:textColor="@color/white"
            android:textColorHint="#88FFFFFF" />

        <EditText
            android:id="@+id/cameraPort"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/camera_port_hint"
            android:inputType="number"
            android:textColor="@color/white"
            android:textColorHint="#88FFFFFF" />

        <CheckBox
            android:id="@+id/cameraEnabled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/camera_enabled"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/cameraStatus"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/buhler_teal"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/cameraTest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_pill_teal"
                android:paddingLeft="24dp"
                android:paddingTop="12dp"
                android:paddingRight="24dp"
                android:paddingBottom="12dp"
                android:text="@string/camera_test"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/cameraSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_teal"
                android:paddingLeft="24dp"
                android:paddingTop="12dp"
                android:paddingRight="24dp"
                android:paddingBottom="12dp"
                android:text="@string/camera_save"
                android:textColor="@color/white"
                android:textSize="16sp" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminCameraBack"
            style="@style/AdminMenuButton"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="@string/admin_back" />
    </LinearLayout>
</merge>
