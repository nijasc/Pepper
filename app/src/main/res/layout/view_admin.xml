<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="android.widget.FrameLayout">

    <LinearLayout
        android:id="@+id/adminPinPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_pin_title"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminPinDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:letterSpacing="0.3"
            android:text="○ ○ ○ ○"
            android:textColor="@color/buhler_teal"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/adminPinError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/admin_pin_error"
            android:textColor="@color/pad_red"
            android:textSize="18sp"
            android:visibility="invisible" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey1" style="@style/AdminKey" android:text="1" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey2" style="@style/AdminKey" android:text="2" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey3" style="@style/AdminKey" android:text="3" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey4" style="@style/AdminKey" android:text="4" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey5" style="@style/AdminKey" android:text="5" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey6" style="@style/AdminKey" android:text="6" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey7" style="@style/AdminKey" android:text="7" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey8" style="@style/AdminKey" android:text="8" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey9" style="@style/AdminKey" android:text="9" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKeyClear" style="@style/AdminKey" android:text="@string/admin_key_clear" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKey0" style="@style/AdminKey" android:text="0" />
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/adminKeyBackspace" style="@style/AdminKey" android:text="@string/admin_key_backspace" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminPinCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@android:color/transparent"
            android:text="@string/admin_cancel"
            android:textColor="#CCFFFFFF"
            android:textSize="18sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminMenuPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/admin_menu_title"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminClearHistory"
            style="@style/AdminMenuButton"
            android:text="@string/admin_clear_history" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminDevLogs"
            style="@style/AdminMenuButton"
            android:text="@string/admin_dev_logs" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminSelfies"
            style="@style/AdminMenuButton"
            android:text="@string/admin_selfies" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminLanguage"
            style="@style/AdminMenuButton"
            android:text="@string/admin_language" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminHistory"
            style="@style/AdminMenuButton"
            android:text="@string/admin_history_view" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminClose"
            style="@style/AdminMenuButton"
            android:layout_marginTop="32dp"
            android:text="@string/admin_close" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminDevLogPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_dev_logs"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <ScrollView
            android:id="@+id/adminDevLogScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/adminDevLogText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="#DDFFFFFF"
                android:textSize="15sp" />
        </ScrollView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminDevLogBack"
            style="@style/AdminMenuButton"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="@string/admin_back" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminGalleryPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_selfies"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/adminSelfieGrid"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/adminGalleryEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/admin_no_selfies"
                android:textColor="#CCFFFFFF"
                android:textSize="20sp"
                android:visibility="gone" />
        </FrameLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminGalleryBack"
            style="@style/AdminMenuButton"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="@string/admin_back" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminDetailPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/adminDetailImage"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:contentDescription="@string/admin_selfies"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/adminDetailNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminDetailDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#CCFFFFFF"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminDetailFavorite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_pill_teal"
                android:paddingLeft="28dp"
                android:paddingTop="14dp"
                android:paddingRight="28dp"
                android:paddingBottom="14dp"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminDetailDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_red"
                android:paddingLeft="28dp"
                android:paddingTop="14dp"
                android:paddingRight="28dp"
                android:paddingBottom="14dp"
                android:text="@string/admin_delete"
                android:textColor="@color/white"
                android:textSize="18sp" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminDetailBack"
            style="@style/AdminMenuButton"
            android:layout_marginTop="10dp"
            android:text="@string/admin_back" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminLangPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/admin_language"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminLangCurrent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColor="@color/buhler_teal"
            android:textSize="20sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminLangDe"
            style="@style/AdminMenuButton"
            android:text="@string/lang_german" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminLangEn"
            style="@style/AdminMenuButton"
            android:text="@string/lang_english" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminLangBack"
            style="@style/AdminMenuButton"
            android:layout_marginTop="24dp"
            android:text="@string/admin_back" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminHistoryPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_history_view"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <ScrollView
            android:id="@+id/adminHistoryScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:id="@+id/adminHistoryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminHistoryBack"
            style="@style/AdminMenuButton"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="@string/admin_back" />
    </LinearLayout>
</merge>
